{
	"compilerOptions": {
		"strict": true,
		"module": "NodeNext",
		"target": "ES2020",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	}
}
